# Atomic Cloud production environment — copy to deploy/.env and fill in.
# Maps 1:1 onto DEPLOY.md §8's checklist. NEVER commit .env (gitignored).
# Secrets ride the environment, not argv, so they stay out of process listings.

# ─── Stack / proxy ──────────────────────────────────────────────────────────

# The launch base domain. Drives host-split routing, cookie scope, redirects.
ATOMIC_CLOUD_BASE_DOMAIN=atomicapp.ai

# ACME registration contact for the wildcard certificate.
ACME_EMAIL=

# Cloudflare API token, scope: Zone → DNS → Edit on the base domain's zone.
# Used by Caddy for the DNS-01 wildcard challenge (and by scripts/provision.sh
# to create the DNS records).
CLOUDFLARE_API_TOKEN=

# Caddy fronts the pod and appends a trustworthy X-Forwarded-For (§4).
ATOMIC_CLOUD_TRUST_PROXY_HEADER=true

# Pod image; deploy.sh --build overrides by building on the box.
ATOMIC_CLOUD_IMAGE=ghcr.io/kenforthewin/atomic-cloud:latest

# ─── Postgres ───────────────────────────────────────────────────────────────

# Superuser password for the colocated cluster (owner of CREATE/DROP DATABASE).
# Generate: openssl rand -hex 24
POSTGRES_PASSWORD=

# Where the cluster keeps its data on the host — the DO volume mount
# (encrypted at rest by DigitalOcean; mounted by cloud-init).
POSTGRES_DATA_DIR=/mnt/atomic-data/postgres

# The control-plane and cluster URLs are composed in docker-compose.yml from
# POSTGRES_PASSWORD (env_file values aren't interpolated; the compose
# `environment:` block is). Both connect DIRECTLY to Postgres — transaction
# pooling breaks the app's session advisory locks (§6). They carry no
# sslmode: the link is a docker bridge on one host, so the boot TLS warning
# for these two URLs is expected and documented (§2's out-of-band case).

# ─── Master key (credential encryption at rest) ─────────────────────────────

# 32 bytes hex. Generate: openssl rand -hex 32
# CUSTODY: back this up out of band, SEPARATE from database backups
# (DEPLOY.md §2). Losing it makes every stored provider credential
# unrecoverable; storing it next to the dumps makes the dumps plaintext.
ATOMIC_CLOUD_MASTER_KEY=

# ─── Managed AI provisioning (OpenRouter) ───────────────────────────────────

# 'openrouter' mints a per-account runtime key at signup, sized to the plan
# allowance. The master balance is the spend firewall: deposit modestly,
# leave auto-topup OFF.
ATOMIC_CLOUD_PROVISIONING_MODE=openrouter
ATOMIC_CLOUD_OPENROUTER_PROVISIONING_KEY=

# ─── Backups (S3-compatible — Cloudflare R2) ────────────────────────────────

# NEVER 'local' in production (MIG-1): the final pre-deletion dump is the only
# undo for a hard delete, and pod-local disk is not durable.
ATOMIC_CLOUD_BACKUP_STORE=s3
ATOMIC_CLOUD_BACKUP_BUCKET=atomic-cloud-backups
ATOMIC_CLOUD_BACKUP_REGION=auto
# R2 endpoint: https://<account-id>.r2.cloudflarestorage.com
ATOMIC_CLOUD_BACKUP_ENDPOINT=
# R2 S3 API credentials (Object Read & Write on the bucket).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Email (Mailgun) ────────────────────────────────────────────────────────

# 'mailgun' in production. 'log' writes magic links to the pod log — useful
# ONLY for the first pre-DNS boot check, never once real users exist.
ATOMIC_CLOUD_EMAIL_MODE=mailgun
ATOMIC_CLOUD_MAILGUN_API_KEY=
ATOMIC_CLOUD_MAILGUN_DOMAIN=mg.atomicapp.ai
ATOMIC_CLOUD_MAILGUN_FROM=Atomic <no-reply@mg.atomicapp.ai>

# ─── Billing (Stripe) — optional at launch ──────────────────────────────────

# Leave unset to run billing-disabled (billing routes return a structured 503;
# trials still run and downgrade to free). To enable: secret key, webhook
# signing secret (endpoint: https://app.<base-domain>/billing/webhook), and
# the plan→price map.
#STRIPE_SECRET_KEY=
#STRIPE_WEBHOOK_SECRET=
#ATOMIC_CLOUD_STRIPE_PRICES=pro=price_...

# ─── Safety rails (do not change in production) ─────────────────────────────

# ATOMIC_CLOUD_DANGEROUSLY_INSECURE_COOKIES must stay unset (§2).
# ATOMIC_CLOUD_ALLOW_PRIVATE_PROVIDER_URLS must stay unset (BYOK SSRF gate).
# ATOMIC_CLOUD_REAPER_INTERVAL_SECS=0 disables the reaper — leave default.
