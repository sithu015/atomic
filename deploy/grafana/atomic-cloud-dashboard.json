{
  "title": "Atomic Cloud \u2014 Single Box",
  "uid": "atomic-cloud-single-box",
  "tags": [
    "atomic-cloud"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "refresh": "1m",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "Backups (scaling doc #6 \u2014 the placebo lesson)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Last successful pass age",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "atomic_cloud_backup_last_success_age_seconds",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 90000
              },
              {
                "color": "red",
                "value": 129600
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Stale tenants (>36h)",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "targets": [
        {
          "expr": "atomic_cloud_backup_stale_tenants",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Last pass: backed up / failed",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "targets": [
        {
          "expr": "atomic_cloud_backup_last_pass_backed_up",
          "refId": "A",
          "legendFormat": "backed up"
        },
        {
          "expr": "atomic_cloud_backup_last_pass_failed",
          "refId": "B",
          "legendFormat": "failed"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list"
        }
      }
    },
    {
      "type": "row",
      "title": "Dispatcher (scaling doc #2)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "title": "Tick age (dead loop = grows)",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 9
      },
      "targets": [
        {
          "expr": "atomic_cloud_dispatcher_last_tick_age_seconds",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 300
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Full scan: duration / tenants polled",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 9
      },
      "targets": [
        {
          "expr": "atomic_cloud_dispatcher_last_full_scan_seconds",
          "refId": "A",
          "legendFormat": "seconds"
        },
        {
          "expr": "atomic_cloud_dispatcher_last_full_scan_tenants",
          "refId": "B",
          "legendFormat": "tenants"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Jobs: executed / deferred (rate)",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 9
      },
      "targets": [
        {
          "expr": "rate(atomic_cloud_dispatcher_jobs_executed_total[5m])",
          "refId": "A",
          "legendFormat": "executed/s"
        },
        {
          "expr": "rate(atomic_cloud_dispatcher_jobs_deferred_total[5m])",
          "refId": "B",
          "legendFormat": "deferred/s"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list"
        }
      }
    },
    {
      "type": "row",
      "title": "Cache & pools (scaling doc #1, #2)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "AccountCache residency by kind",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 17
      },
      "targets": [
        {
          "expr": "atomic_cloud_account_cache_entries",
          "refId": "A",
          "legendFormat": "{{kind}}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Worker pools: in-flight vs cap",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 17
      },
      "targets": [
        {
          "expr": "atomic_cloud_worker_pool_in_flight",
          "refId": "A",
          "legendFormat": "{{class}} in-flight"
        },
        {
          "expr": "atomic_cloud_worker_pool_cap",
          "refId": "B",
          "legendFormat": "{{class}} cap"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Connections: tenant pools + control / cluster total",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 17
      },
      "targets": [
        {
          "expr": "atomic_cloud_tenant_pool_connections",
          "refId": "A",
          "legendFormat": "tenant pools"
        },
        {
          "expr": "atomic_cloud_control_pool_connections",
          "refId": "B",
          "legendFormat": "control pool"
        },
        {
          "expr": "sum(pg_stat_activity_count)",
          "refId": "C",
          "legendFormat": "cluster total"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list"
        }
      }
    },
    {
      "type": "row",
      "title": "Host (scaling doc #5, #8 \u2014 disk is the hard wall)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Disk available % (data volume)",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 25
      },
      "targets": [
        {
          "expr": "100 * node_filesystem_avail_bytes{fstype=\"ext4\"} / node_filesystem_size_bytes{fstype=\"ext4\"}",
          "refId": "A",
          "legendFormat": "{{mountpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "CPU busy %",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 25
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "refId": "A",
          "legendFormat": "busy"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Memory available",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 25
      },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes",
          "refId": "A",
          "legendFormat": "available"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list"
        }
      }
    },
    {
      "type": "row",
      "title": "Postgres (scaling doc #1, #7)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Connections by database (top)",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 33
      },
      "targets": [
        {
          "expr": "topk(10, sum by (datname) (pg_stat_activity_count))",
          "refId": "A",
          "legendFormat": "{{datname}}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Database sizes (top \u2014 the overcommit picture)",
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 33
      },
      "targets": [
        {
          "expr": "topk(10, pg_database_size_bytes)",
          "refId": "A",
          "legendFormat": "{{datname}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list"
        }
      }
    }
  ]
}